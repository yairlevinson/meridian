# Minimal PX4 SITL image — no Gazebo, no rendering.
# Native ARM64 + AMD64 support.
#
# Build (one-time, ~5 min):
#   docker build -t qgc-px4-sitl -f Dockerfile.px4-sitl .
#
# Run:
#   docker run --rm -p 5760:5760 qgc-px4-sitl
#
# PX4 sends MAVLink on UDP 14550 internally.
# MAVProxy bridges to TCP 5760 for external clients (QGC, E2E tests).

FROM ubuntu:22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    git cmake build-essential g++ python3 python3-pip python3-venv \
    python3-jinja2 python3-empy python3-packaging python3-jsonschema \
    python3-yaml python3-toml python3-numpy python3-requests \
    libxml2-dev libxslt1-dev ninja-build zip gawk \
    && rm -rf /var/lib/apt/lists/*

# Clone PX4 v1.15.4 with tags (needed by build scripts)
RUN git clone --branch v1.15.4 --recursive --shallow-submodules --jobs 4 \
    https://github.com/PX4/PX4-Autopilot.git /px4

WORKDIR /px4

# Install Python deps PX4 build needs
RUN pip3 install --no-cache-dir --break-system-packages \
    kconfiglib pyros-genmsg future lxml 2>/dev/null || \
    pip3 install --no-cache-dir kconfiglib pyros-genmsg future lxml

# Build SITL firmware only — DONT_RUN=1 prevents auto-launch
RUN DONT_RUN=1 make px4_sitl_default

# --- Runtime stage ---
FROM ubuntu:22.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip netcat-openbsd \
    && pip3 install --no-cache-dir --break-system-packages \
       future pymavlink MAVProxy 2>/dev/null || \
       pip3 install --no-cache-dir future pymavlink MAVProxy \
    && rm -rf /var/lib/apt/lists/*

# Copy the built PX4 SITL binary and config
COPY --from=builder /px4/build/px4_sitl_default /px4/build/px4_sitl_default
COPY --from=builder /px4/ROMFS /px4/ROMFS
COPY --from=builder /px4/test_data /px4/test_data

WORKDIR /px4

# TCP port for QGC/app connections (via MAVProxy bridge)
EXPOSE 5760

# PX4_SIM_MODEL=none tells PX4 not to wait for a physics sim
ENV PX4_SIM_MODEL=none
ENV PX4_SIM_SPEED_FACTOR=1

COPY <<'ENTRYPOINT_SCRIPT' /entrypoint.sh
#!/bin/bash
set -e

# Start MAVProxy to bridge PX4's internal UDP 14550 → external TCP 5760
# --daemon runs in background; tcpin means MAVProxy listens for TCP connections
python3 -m MAVProxy.mavproxy \
  --daemon \
  --master=udpin:127.0.0.1:14550 \
  --out=tcpin:0.0.0.0:5760 \
  2>&1 > /tmp/mavproxy.log &

# Give MAVProxy a moment to bind its ports
sleep 1

# Run PX4 SITL directly (no physics sim, just firmware + MAVLink)
exec /px4/build/px4_sitl_default/bin/px4 \
  /px4/ROMFS/px4fmu_common \
  -s etc/init.d-posix/rcS \
  -t /px4/test_data
ENTRYPOINT_SCRIPT

RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
