# Minimal PX4 SITL image — no Gazebo, no rendering.
# Native ARM64 + AMD64 support.
#
# Build (one-time, ~5 min, from repo root):
#   docker build -t meridian-px4-sitl:latest -f test/e2e/sitl/Dockerfile.px4-sitl .
#
# Run:
#   docker run --rm -p 5760:5760 meridian-px4-sitl
#
# PX4 sends MAVLink on UDP 14550 internally.
# MAVProxy bridges to TCP 5760 for external clients (Meridian, E2E tests).

FROM ubuntu:22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    git cmake build-essential g++ python3 python3-pip python3-venv \
    python3-jinja2 python3-empy python3-packaging python3-jsonschema \
    python3-yaml python3-toml python3-numpy python3-requests \
    libxml2-dev libxslt1-dev ninja-build zip gawk \
    && rm -rf /var/lib/apt/lists/*

# Clone PX4 v1.15.4 with tags (needed by build scripts)
RUN git clone --branch v1.15.4 --recursive --shallow-submodules --jobs 4 \
    https://github.com/PX4/PX4-Autopilot.git /px4

WORKDIR /px4

# Install Python deps PX4 build needs
RUN pip3 install --no-cache-dir --break-system-packages \
    kconfiglib pyros-genmsg future lxml 2>/dev/null || \
    pip3 install --no-cache-dir kconfiglib pyros-genmsg future lxml

# Build SITL firmware only — DONT_RUN=1 prevents auto-launch
RUN DONT_RUN=1 make px4_sitl_default

# --- Runtime stage ---
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip netcat-openbsd bc \
    && pip3 install --no-cache-dir --break-system-packages \
       future pymavlink MAVProxy 2>/dev/null || \
       pip3 install --no-cache-dir future pymavlink MAVProxy \
    && rm -rf /var/lib/apt/lists/*

# Copy the built PX4 SITL binary and config
COPY --from=builder /px4/build/px4_sitl_default /px4/build/px4_sitl_default
COPY --from=builder /px4/ROMFS /px4/ROMFS
COPY --from=builder /px4/test_data /px4/test_data

WORKDIR /px4

# TCP port for Meridian/app connections (via MAVProxy bridge)
EXPOSE 5760

# SIH (Simulator-In-Hardware): PX4's built-in physics sim, no external
# simulator needed. Airframe 10040 = sihsim_quadx.
ENV PX4_SIM_MODEL=sihsim_quadx
ENV PX4_SIM_SPEED_FACTOR=1

# Configurable home position (defaults to Boston)
ENV PX4_HOME_LAT=42.3898
ENV PX4_HOME_LON=-71.1476
ENV PX4_HOME_ALT=14

COPY test/e2e/sitl/write-sitl-params.py /write-sitl-params.py
COPY test/e2e/sitl/healthcheck.sh /healthcheck.sh
COPY test/e2e/sitl/entrypoint-sitl.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh /healthcheck.sh

HEALTHCHECK --interval=5s --timeout=3s --retries=30 --start-period=30s \
  CMD /healthcheck.sh

ENTRYPOINT ["/entrypoint.sh"]
